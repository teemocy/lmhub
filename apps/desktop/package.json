{
  "name": "@localhub/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "build": "pnpm run build:main && pnpm run build:renderer",
    "build:main": "tsup --config tsup.config.ts",
    "build:renderer": "vite build",
    "dev": "node ./scripts/dev.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@localhub/platform": "workspace:*",
    "@localhub/shared-contracts": "workspace:*",
    "@localhub/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "electron": "^30.5.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
